# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=ifrs16
DB_PASSWORD=ifrs16_secret
DB_NAME=ifrs16

# MinIO 配置
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# 服务端口
CORE_PORT=8080
AI_PORT=8081
WEB_PORT=3000

# JWT 密钥
JWT_SECRET=ifrs16_jwt_secret_key

# LLM 配置（默认使用 DeepSeek）
# 可选: deepseek / openai
LLM_PROVIDER=deepseek

# DeepSeek API Key & 模型
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# 可用模型:
# - deepseek-v4-flash    (非思考模式，速度快，成本低)
# - deepseek-v4-pro      (思考模式，推理能力强)
# - deepseek-chat        (兼容旧版，2026/07/24 弃用)
# - deepseek-reasoner    (兼容旧版，2026/07/24 弃用)

# OpenAI API Key（备用）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 日志级别
LOG_LEVEL=info
